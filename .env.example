# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Public URL of the deployed app (optional).
APP_URL="MY_APP_URL"

# ALLOW_DEV_BILLING=1 enables plan activation without Apple IAP (local + TestFlight testing).
# Leave unset/0 on public production once App Store IAP is live.
ALLOW_DEV_BILLING=1
